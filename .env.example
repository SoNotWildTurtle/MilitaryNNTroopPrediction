# Example environment variables for MilitaryNNTroopPrediction
MONGO_URI=mongodb://localhost:27017
MONGO_DB=troops
SENTINEL_CLIENT_ID=your-client-id
SENTINEL_CLIENT_SECRET=your-secret
SENTINEL_INSTANCE_ID=your-instance-id
UI_LANG=en
DATA_DIR=data
OPENAI_API_KEY=your-openai-key
SOURCE_CATALOG=sources.json
CAMERA_WEIGHT=1.0
LIDAR_WEIGHT=1.0
BLUETOOTH_WEIGHT=1.0
RESOLUTION_SCALE=1.0
FEATURE_RICHNESS=1.0
HIGH_MEMORY_MODE=0
